# Copy to .env if you want to override defaults. Pinned versions = repeatable builds.
# The relay version MUST match the engine's iroh-relay dep (Cargo.toml: iroh-relay = "0.95.1")
# so the relay protocol matches the peers' iroh 0.95 client.
IROH_RELAY_VERSION=0.95.1
RUST_LOG=info

# Read by the rung tests (tests/substrate_relay.rs). Defaults shown.
CYAN_RELAY_URL=http://cyan-rig-relay:3340
CYAN_NODE_IMAGE=cyan/node:rig
